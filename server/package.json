{
  "name": "cricket-auction-server",
  "version": "1.0.0",
  "description": "Production-grade realtime multiplayer cricket auction engine",
  "main": "src/index.js",
  "scripts": {
    "start": "PYTHON_BIN=${PYTHON_BIN:-python3.11} node src/index.js",
    "dev": "nodemon src/index.js",
    "build:client": "npm --prefix ../client run build",
    "seed": "node src/seed/index.js",
    "seed:stats": "node src/seed/seedPlayerStats.js",
    "seed:profiles": "node src/seed/seedProfileData.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
