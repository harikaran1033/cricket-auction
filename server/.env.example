# ─────────────────────────────────────────
# Cricket Auction Server — Environment File
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# Server port
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/cricket-auction

# Node environment: development | production | test
NODE_ENV=development

# Client URL for CORS (comma-separate multiple origins if needed)
CLIENT_URL=http://localhost:5173

# Optional: Redis URL for horizontal scaling (Socket.IO multi-instance)
# REDIS_URL=redis://localhost:6379
